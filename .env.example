# Supabase (from your project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser
# Use the new secret key (recommended) OR legacy service_role JWT
SUPABASE_SECRET_KEY=sb_secret_your-key-here
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...legacy-service-role-jwt

# OpenRouter (server-only — powers /api/v1/chat)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Embedding model for RAG (must match vector size in Supabase — see docs/SYSTEM_EVOLUTION.md)
# Default: nvidia/llama-nemotron-embed-vl-1b-v2:free (2048-dim)
# Alternative: openai/text-embedding-3-small (1536-dim, supports HNSW index)
# If you change this model: update lib/embeddings.ts dimensions, migrate DB if needed, then npm run embed-knowledge
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# App URL — this developer portal (production: https://developers.tanyalahustaz.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Rate limiting (uses api_usage + partner_chat_logs tables — no extra service needed)
# Set RATE_LIMIT_ENABLED=false to disable locally
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT_PER_MINUTE=20
RATE_LIMIT_CHAT_PER_DAY=500
RATE_LIMIT_API_PER_MINUTE=60
RATE_LIMIT_API_PER_DAY=2000
RATE_LIMIT_PLAYGROUND_PER_MINUTE=10
RATE_LIMIT_PLAYGROUND_PER_DAY=50

# Signup access control (default: invite-only)
# Set SIGNUP_MODE=open for public registration (e.g. local dev)
SIGNUP_MODE=invite
# Comma-separated invite codes (hashed server-side for DB invites)
SIGNUP_INVITE_CODES=your-beta-invite-code

# Sentry error monitoring (optional — leave blank to disable)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Vercel Cron secret for /api/cron/embed-jobs (set in Vercel dashboard)
CRON_SECRET=generate-a-long-random-secret

# Background embedding job batch size
EMBED_JOB_BATCH_SIZE=5

# Consumer app (B2C) — linked from auth pages and footer
NEXT_PUBLIC_CONSUMER_APP_URL=https://tanyalahustaz.com/home
